{
  "name": "soundcloud-player",
  "version": "1.1.0",
  "description": "SoundCloud Desktop Player",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "jimp": "^1.6.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "to-ico": "^1.1.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "axios": "^1.7.7",
    "color-thief-browser": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.1"
  },
  "build": {
    "appId": "com.soundcloud.player",
    "productName": "SoundCloud",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "buildResources/tray_clean.png",
        "to": "tray_clean.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "buildResources/icon_rounded.ico"
    }
  }
}
